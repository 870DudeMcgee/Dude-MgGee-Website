# Shopify Storefront API
# Public products and basic cart creation use Shopify's tokenless Storefront API.
# These values are optional overrides for local/Vercel environments.
SHOPIFY_STORE_DOMAIN=dude-mcgee-merch.myshopify.com
SHOPIFY_STOREFRONT_API_VERSION=2026-07

# Optional: a private Headless storefront token. Keep this server-side in
# Vercel; never expose it in browser JavaScript or commit a real value.
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=
